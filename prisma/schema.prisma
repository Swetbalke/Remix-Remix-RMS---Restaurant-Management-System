generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("MONGODB_URL")
}

model User {
  id             String         @id @default(auto()) @map("_id") @db.ObjectId
  name           String
  email          String         @unique
  role           String         @default("EMPLOYEE")
  passwordHash   String
  isActive       Boolean        @default(true)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  RefreshToken   RefreshToken[]
  CustomerOrders Order[]        @relation("CustomerOrders")
  EmployeeOrders Order[]        @relation("EmployeeOrders")
}

model RefreshToken {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  userId      String   @db.ObjectId
  hashedToken String
  expiresAt   DateTime
  revoked     Boolean  @default(false)
  user        User     @relation(fields: [userId], references: [id])
}

model Category {
  id          String     @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  description String?
  emoji       String?    @default("🍽")
  isActive    Boolean    @default(true)
  MenuItems   MenuItem[]
}

model MenuItem {
  id              String      @id @default(auto()) @map("_id") @db.ObjectId
  categoryId      String      @db.ObjectId
  name            String
  description     String?
  imageUrl        String?
  price           Float
  isAvailable     Boolean     @default(true)
  isVeg           Boolean     @default(true)
  preparationTime Int? // in minutes
  // FoodZone additional fields
  emoji           String?     @default("🍽")
  tag             String?
  rating          Float?      @default(4.0)
  reviewCount     Int?        @default(0)
  prepTime        String?     @default("20 mins")
  nutrition       Json?       // [{value: String, label: String}]
  sideOptions     Json?       // [{sideId: Int, emoji: String, name: String, price: Float}]
  category        Category    @relation(fields: [categoryId], references: [id])
  OrderItems      OrderItem[]
  RecipeBOM       RecipeBOM[]
}

model RestaurantTable {
  id       String  @id @default(auto()) @map("_id") @db.ObjectId
  name     String
  capacity Int
  status   String  @default("FREE")
  Orders   Order[]
}

model Order {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  tableId       String?  @db.ObjectId
  userId        String?  @db.ObjectId
  employeeId    String?  @db.ObjectId
  status        String   @default("PENDING")
  orderType     String   @default("DINEIN")
  totalAmount   Float    @default(0)
  paymentStatus String   @default("UNPAID")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  table      RestaurantTable? @relation(fields: [tableId], references: [id])
  user       User?            @relation(name: "CustomerOrders", fields: [userId], references: [id])
  employee   User?            @relation(name: "EmployeeOrders", fields: [employeeId], references: [id])
  OrderItems OrderItem[]
  Payments   Payment[]
}

model OrderItem {
  id         String  @id @default(auto()) @map("_id") @db.ObjectId
  orderId    String  @db.ObjectId
  menuItemId String  @db.ObjectId
  quantity   Int
  unitPrice  Float
  modifiers  String? // Stored as JSON string

  order    Order    @relation(fields: [orderId], references: [id])
  menuItem MenuItem @relation(fields: [menuItemId], references: [id])
}

model Payment {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  orderId        String   @db.ObjectId
  amount         Float
  method         String
  transactionRef String?
  status         String   @default("PAID")
  paidAt         DateTime @default(now())

  order Order @relation(fields: [orderId], references: [id])
}

model Ingredient {
  id             String          @id @default(auto()) @map("_id") @db.ObjectId
  name           String
  stockQty       Float           @default(0)
  unit           String
  reorderLevel   Float           @default(0)
  costPrice      Float           @default(0)
  RecipeBOM      RecipeBOM[]
  StockMovements StockMovement[]
}

model RecipeBOM {
  id               String @id @default(auto()) @map("_id") @db.ObjectId
  menuItemId       String @db.ObjectId
  ingredientId     String @db.ObjectId
  quantityRequired Float

  menuItem   MenuItem   @relation(fields: [menuItemId], references: [id])
  ingredient Ingredient @relation(fields: [ingredientId], references: [id])
}

model StockMovement {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  ingredientId String   @db.ObjectId
  changeQty    Float
  reason       String
  referenceId  String?
  createdAt    DateTime @default(now())

  ingredient Ingredient @relation(fields: [ingredientId], references: [id])
}
